{
  "manifest_version": 3,
  "name": "Tab Bankruptcy",
  "version": "1.0.1",
  "description": "Save all your open tabs to bookmarks and declare tab bankruptcy",
  "permissions": [
    "bookmarks",
    "tabs"
  ],
  "web_accessible_resources": [
    {
      "resources": ["media/*.webp"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
